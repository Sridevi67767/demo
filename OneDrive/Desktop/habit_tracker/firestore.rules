// ============================================================
// FILE: firestore.rules
// PURPOSE: Security rules for your Firestore database.
//
// These rules make sure:
//   - Only logged-in users can read/write data
//   - Each user can ONLY access their own data (not others')
//
// HOW TO DEPLOY THESE RULES:
//   1. Go to Firebase Console → Firestore Database → Rules tab
//   2. Paste the rules block below into the editor
//   3. Click "Publish"
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own documents
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
